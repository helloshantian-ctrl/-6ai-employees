# ===== Claude API =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== Frontend access (existing chat UI) =====
ACCESS_PASSWORD=your-chat-password

# ===== HTTP Basic auth for dashboards (optional, used by middleware.js) =====
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# ===== Supabase (Postgres + REST) =====
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE=ey...   # service_role key, server-side only

# ===== Admin API token (for /api/sources, /api/users, manual ingest) =====
ADMIN_TOKEN=generate-a-random-64-char-token

# ===== Vercel Cron =====
# Set this to a long random string. Vercel will send it as Authorization: Bearer
# whenever a cron triggers. Endpoints in /api/cron/* check it.
CRON_SECRET=generate-a-random-cron-secret

# ===== Email delivery (Resend) =====
RESEND_API_KEY=re_...
RESEND_FROM="AI Briefing <briefing@yourdomain.com>"

# ===== Email ingest (Resend Inbound, optional) =====
# Resend Inbound posts incoming emails to /api/ingest/email; we verify this.
RESEND_INBOUND_SECRET=

# ===== Scrape worker (optional, headless browser) =====
# If you self-host a Playwright worker, set its base URL + auth.
SCRAPE_WORKER_URL=
SCRAPE_WORKER_TOKEN=
